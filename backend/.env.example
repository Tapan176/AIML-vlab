# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017/
DB_NAME=aiml-lab

# JWT Configuration
JWT_SECRET=CHANGE_ME_IN_PRODUCTION
JWT_EXPIRY_HOURS=24

# File Storage Paths
UPLOAD_DIR=static/uploads
TRAINED_MODELS_DIR=trainedModels
IMAGES_DIR=static/images
PREDICTIONS_DIR=predictions

# Server Configuration
FLASK_PORT=5050
FLASK_DEBUG=true

# CORS — comma-separated frontend origins
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Google Drive — Local development paths (optional)
# GOOGLE_CREDENTIALS_PATH=/path/to/credentials.json
# GOOGLE_TOKEN_PATH=/path/to/token.json

# Allowed File Extensions
ALLOWED_CSV_EXTENSIONS=csv
ALLOWED_IMAGE_EXTENSIONS=jpg,jpeg,png
ALLOWED_ARCHIVE_EXTENSIONS=zip
MAX_UPLOAD_SIZE_MB=50

# --- VERCEL DEPLOYMENT ---
# For Vercel Serverless, provide the raw JSON string of credentials.json and token.json
# GOOGLE_CREDENTIALS_JSON='{"web":{"client_id":"...","project_id":"..."}}'
# GOOGLE_TOKEN_JSON='{"token":"...","refresh_token":"..."}'
